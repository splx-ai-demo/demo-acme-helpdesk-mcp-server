# AcmeCorp Helpdesk MCP — local configuration
#
# In production these values are injected by Vault. For local dev, copy this
# file to .env and fill in the placeholders below.

HELPDESK_DB_PATH=./helpdesk.db

HELPDESK_API_TOKEN=demo-bearer-acme-internal

NOTIFICATION_HMAC_TOKEN=hmac-internal-acme-7a3f9e2c4b1d8e0f

NOTIFICATION_WEBHOOK_URL=http://127.0.0.1:9009/notify

HELPDESK_BIN_PATH=./bin
