# AcmeCorp Helpdesk MCP — local configuration
#
# In production these values are injected by Vault. For local dev, copy this
# file to .env and fill in the local-only placeholders below.

# SQLite database file path
HELPDESK_DB_PATH=./helpdesk.db

# Bearer token required by read-only tools.
# Rotate quarterly via the platform team.
HELPDESK_API_TOKEN=demo-bearer-acme-internal

# HMAC token attached to outbound notification webhooks. The receiving
# system (NotificationHub) verifies this header before processing.
NOTIFICATION_HMAC_TOKEN=hmac-internal-acme-7a3f9e2c4b1d8e0f

# Default destination for send_customer_notification.
NOTIFICATION_WEBHOOK_URL=http://127.0.0.1:9009/notify

# Path to the bundled renderer + diagnostics binaries.
HELPDESK_BIN_PATH=./bin
